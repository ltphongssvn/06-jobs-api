		{
			"name": "Register User",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"// Test response structure",
							"pm.test(\"Response has token and user\", function () {",
							"    const jsonData = pm.response.json();",
							"    pm.expect(jsonData).to.have.property('token');",
							"    pm.expect(jsonData).to.have.property('user');",
							"    pm.expect(jsonData.user).to.have.property('name');",
							"});",
							"",
							"// Test status code",
							"pm.test(\"Status code is 201\", function () {",
							"    pm.response.to.have.status(201);",
							"});",
							"",
							"// Extract and save the token for use in other requests",
							"if (pm.response.code === 201) {",
							"    const jsonData = pm.response.json();",
							"    ",
							"    // Save token to collection variables",
							"    pm.collectionVariables.set(\"token\", jsonData.token);",
							"    pm.collectionVariables.set(\"currentUserName\", jsonData.user.name);",
							"    ",
							"    // Log for debugging",
							"    console.log(\"Token saved to collection variables\");",
							"    console.log(\"User registered:\", jsonData.user.name);",
							"}"
						],
						"type": "text/javascript",
						"packages": {}
					}
				}
			],
