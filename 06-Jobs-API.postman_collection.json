		{
			"name": "Create Job",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Status code is 201\", function () {",
							"    pm.response.to.have.status(201);",
							"});",
							"",
							"pm.test(\"Response has job with all fields\", function () {",
							"    const jsonData = pm.response.json();",
							"    pm.expect(jsonData.job).to.exist;",
							"    pm.expect(jsonData.job).to.have.property('_id');",
							"    pm.expect(jsonData.job).to.have.property('company');",
							"    pm.expect(jsonData.job).to.have.property('position');",
							"    pm.expect(jsonData.job).to.have.property('status');",
							"    pm.expect(jsonData.job).to.have.property('createdBy');",
							"});",
							"",
							"// Save the job ID to collection variables for use in other requests",
							"const jsonData = pm.response.json();",
							"if (jsonData.job && jsonData.job._id) {",
							"    pm.collectionVariables.set(\"jobId\", jsonData.job._id);",
							"    console.log(\"Job ID saved: \" + jsonData.job._id);",
							"}"
						],
						"type": "text/javascript",
						"packages": {}
					}
				}
			],
